# ==========================================
# REQUIRED (Production / Vercel)
# ==========================================
# Supabase pooled connection (port 6543, pgbouncer=true)
DATABASE_URL=postgresql://<db_user>:<db_password>@<project-ref>.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (port 5432) for Prisma migrations/introspection
DIRECT_URL=postgresql://<db_user>:<db_password>@db.<project-ref>.supabase.co:5432/postgres

# NextAuth secrets (use the same random value for both)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=<generate-long-random-secret>
AUTH_SECRET=<same-as-nextauth-secret>

# Public app URL on Vercel
NEXTAUTH_URL=https://<your-vercel-domain>

# Helpful on Vercel for NextAuth v5 deployments
AUTH_TRUST_HOST=true

# ==========================================
# OPTIONAL (Only if integration enabled)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# External notification integration (currently out of scope)
WHATSAPP_API_KEY=<whatsapp-api-key>
WHATSAPP_PHONE_NUMBER_ID=<whatsapp-phone-number-id>
